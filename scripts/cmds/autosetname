const { createCanvas } = require("canvas");
const { writeFileSync, createReadStream, existsSync, mkdirSync } = require("fs-extra");
const path = require("path");

// Fonction pour remplacer les raccourcis
function checkShortCut(nickname, uid, userName) {

	// Remplace {userName} par le nom utilisateur
	/\{userName\}/gi.test(nickname)
		? nickname = nickname.replace(/\{userName\}/gi, userName)
		: null;

	// Remplace {userID} par l'ID utilisateur
	/\{userID\}/gi.test(nickname)
		? nickname = nickname.replace(/\{userID\}/gi, uid)
		: null;

	// Retourne le texte final
	return nickname;
}

module.exports = {

	config: {
		name: "autosetname",
		version: "2.0",
		author: "NTKhang + Derla Kiritö",
		cooldowns: 5,
		role: 1,

		description: {
			vi: "Tự đổi biệt danh cho thành viên mới vào nhóm chat",
			en: "Auto change nickname of new member"
		},

		category: "box chat",

		guide: {
			vi:
				'   {pn} set <nickname>'
				+ '\n   + {userName}'
				+ '\n   + {userID}',

			en:
				'   {pn} set <nickname>'
				+ '\n   + {userName}'
				+ '\n   + {userID}'
		}
	},

	langs: {

		vi: {
			missingConfig: "Vui lòng nhập cấu hình cần thiết",
			configSuccess: "Cấu hình đã được cài đặt thành công",
			currentConfig: "Cấu hình hiện tại:\n%1",
			notSetConfig: "Nhóm chưa cài đặt cấu hình",
			syntaxError: "Sai cú pháp",
			turnOnSuccess: "Đã bật autoSetName",
			turnOffSuccess: "Đã tắt autoSetName",
			error: "Có lỗi xảy ra"
		},

		en: {
			missingConfig: "Please enter the required configuration",
			configSuccess: "Configuration saved successfully",
			currentConfig: "Current configuration:\n%1",
			notSetConfig: "No configuration found",
			syntaxError: "Syntax error",
			turnOnSuccess: "AutoSetName enabled",
			turnOffSuccess: "AutoSetName disabled",
			error: "An error occurred"
		}
	},

	onStart: async function ({
		message,
		event,
		args,
		threadsData,
		getLang
	}) {

		switch (args[0]) {

			// Configuration nickname
			case "set":
			case "add":
			case "config": {

				if (args.length < 2)
					return message.reply(getLang("missingConfig"));

				// Texte nickname
				const configAutoSetName =
					args.slice(1).join(" ");

				// Sauvegarde config
				await threadsData.set(
					event.threadID,
					configAutoSetName,
					"data.autoSetName"
				);

				// Création dossier cache
				const cachePath =
					path.join(__dirname, "cache");

				if (!existsSync(cachePath)) {
					mkdirSync(cachePath);
				}

				// Création canvas
				const canvas =
					createCanvas(1400, 700);

				const ctx =
					canvas.getContext("2d");

				// Fond principal
				ctx.fillStyle = "#101322";
				ctx.fillRect(
					0,
					0,
					canvas.width,
					canvas.height
				);

				// Bordure néon cyan
				ctx.strokeStyle = "#00ffee";
				ctx.lineWidth = 8;
				ctx.strokeRect(
					15,
					15,
					1370,
					670
				);

				// Ombre glow
				ctx.shadowColor = "#00ffee";
				ctx.shadowBlur = 25;

				// Titre
				ctx.fillStyle = "#ffffff";
				ctx.font = "bold 55px Sans";
				ctx.fillText(
					"✨ AUTO SET NAME",
					60,
					90
				);

				// Texte config
				ctx.fillStyle = "#00ffee";
				ctx.font = "bold 42px Sans";

				ctx.fillText(
					configAutoSetName,
					70,
					220
				);

				// Barre
				ctx.fillStyle = "#2b2b2b";
				ctx.fillRect(
					70,
					280,
					500,
					35
				);

				ctx.fillStyle = "#00ffee";
				ctx.fillRect(
					70,
					280,
					400,
					35
				);

				// Pourcentage
				ctx.fillStyle = "#ffffff";
				ctx.font = "28px Sans";
				ctx.fillText(
					"80%",
					280,
					307
				);

				// Exemple
				ctx.fillStyle = "#ffffff";
				ctx.font = "32px Sans";

				ctx.fillText(
					"Preview Example :",
					70,
					400
				);

				ctx.fillStyle = "#00ffee";

				ctx.fillText(
					checkShortCut(
						configAutoSetName,
						"100087654321",
						"Christ St"
					),
					70,
					460
				);

				// Cercle déco
				ctx.beginPath();

				ctx.arc(
					1120,
					300,
					130,
					0,
					Math.PI * 2
				);

				ctx.closePath();

				ctx.fillStyle = "#00ffee";
				ctx.fill();

				// Cercle intérieur
				ctx.beginPath();

				ctx.arc(
					1120,
					300,
					118,
					0,
					Math.PI * 2
				);

				ctx.closePath();

				ctx.fillStyle = "#111111";
				ctx.fill();

				// Emoji
				ctx.font = "100px Sans";
				ctx.fillStyle = "#ffffff";

				ctx.fillText(
					"⚡",
					1085,
					335
				);

				// Footer
				ctx.font = "24px Sans";
				ctx.fillStyle = "#bbbbbb";

				ctx.fillText(
					"Auto Nickname System • GoatBot Messenger",
					60,
					650
				);

				// Sauvegarde image
				const imgPath =
					path.join(
						cachePath,
						`autosetname_${event.threadID}.png`
					);

				const buffer =
					canvas.toBuffer();

				writeFileSync(
					imgPath,
					buffer
				);

				// Envoie image
				return message.reply({
					body: getLang("configSuccess"),
					attachment: createReadStream(imgPath)
				});
			}

			// Voir configuration
			case "view":
			case "info": {

				const configAutoSetName =
					await threadsData.get(
						event.threadID,
						"data.autoSetName"
					);

				return message.reply(
					configAutoSetName
						? getLang(
							"currentConfig",
							configAutoSetName
						)
						: getLang("notSetConfig")
				);
			}

			// Activer / désactiver
			default: {

				const enableOrDisable =
					args[0];

				if (
					enableOrDisable !== "on"
					&&
					enableOrDisable !== "off"
				)

					return message.reply(
						getLang("syntaxError")
					);

				// Sauvegarde état
				await threadsData.set(
					event.threadID,
					enableOrDisable === "on",
					"settings.enableAutoSetName"
				);

				// Création canvas
				const canvas =
					createCanvas(1200, 600);

				const ctx =
					canvas.getContext("2d");

				// Fond
				ctx.fillStyle = "#151515";
				ctx.fillRect(
					0,
					0,
					canvas.width,
					canvas.height
				);

				// Couleur état
				const color =
					enableOrDisable === "on"
						? "#00ff88"
						: "#ff4444";

				// Bordure
				ctx.strokeStyle = color;
				ctx.lineWidth = 8;

				ctx.strokeRect(
					15,
					15,
					1170,
					570
				);

				// Glow
				ctx.shadowColor = color;
				ctx.shadowBlur = 25;

				// Titre
				ctx.fillStyle = "#ffffff";
				ctx.font = "bold 50px Sans";

				ctx.fillText(
					"⚙️ AUTO SET NAME",
					60,
					100
				);

				// État
				ctx.fillStyle = color;
				ctx.font = "bold 90px Sans";

				ctx.fillText(
					enableOrDisable.toUpperCase(),
					380,
					260
				);

				// Texte
				ctx.fillStyle = "#ffffff";
				ctx.font = "35px Sans";

				ctx.fillText(
					enableOrDisable === "on"
						? "Automatic nickname system enabled"
						: "Automatic nickname system disabled",
					60,
					400
				);

				// Sauvegarde
				const cachePath =
					path.join(__dirname, "cache");

				if (!existsSync(cachePath)) {
					mkdirSync(cachePath);
				}

				const imgPath =
					path.join(
						cachePath,
						`autosetname_state_${event.threadID}.png`
					);

				writeFileSync(
					imgPath,
					canvas.toBuffer()
				);

				// Envoie
				return message.reply({
					body:
						enableOrDisable == "on"
							? getLang("turnOnSuccess")
							: getLang("turnOffSuccess"),

					attachment:
						createReadStream(imgPath)
				});
			}
		}
	},

	onEvent: async ({
		message,
		event,
		api,
		threadsData,
		getLang
	}) => {

		// Vérifie si quelqu’un rejoint
		if (event.logMessageType !== "log:subscribe")
			return;

		// Vérifie activation
		if (
			!await threadsData.get(
				event.threadID,
				"settings.enableAutoSetName"
			)
		)
			return;

		// Récupère configuration
		const configAutoSetName =
			await threadsData.get(
				event.threadID,
				"data.autoSetName"
			);

		return async function () {

			// Membres ajoutés
			const addedParticipants =
				[...event.logMessageData.addedParticipants];

			for (const user of addedParticipants) {

				// Données utilisateur
				const {
					userFbId: uid,
					fullName: userName
				} = user;

				try {

					// Change nickname
					await api.changeNickname(
						checkShortCut(
							configAutoSetName,
							uid,
							userName
						),
						event.threadID,
						uid
					);

				} catch (e) {

					// Erreur
					return message.reply(
						getLang("error")
					);
				}
			}
		};
	}
};
